spring:
  datasource:
    url: jdbc:mysql://localhost:3306/instrument_trade?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username:         # DB 사용자명 (예: root)
    password:         # DB 비밀번호
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: update   # 최초 실행: create / 이후: update
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect
    show-sql: true
  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 50MB

jwt:
  secret:                        # 256-bit 이상의 랜덤 HEX 문자열 (예: openssl rand -hex 32)
  access-token-expiry-ms: 1800000    # Access Token 만료 시간 (ms) — 기본 30분
  refresh-token-expiry-ms: 604800000 # Refresh Token 만료 시간 (ms) — 기본 7일

file:
  upload-dir: ./uploads/instruments  # 이미지 저장 경로 (서버 로컬 기준)

logging:
  level:
    org.hibernate.SQL: debug
    org.hibernate.orm.jdbc.bind: trace
